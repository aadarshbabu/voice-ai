// ============================================
// WebRTC Bridge — Audio ↔ EngineOrchestrator
// ============================================
// Connects the server-side WebRTC peer's audio
// stream to the EngineOrchestrator:
//   - Inbound audio → VAD → STT → dispatch events
//   - Outbound effects → TTS → audio frames to peer
// ============================================

import type { ServerPeer } from './server-peer';
import type { OpusDecoder, OpusEncoder } from './audio-transcoder';
import { createOpusDecoder, createOpusEncoder, computeRmsDbfs } from './audio-transcoder';
import type { VoiceEvent } from '../events';

// ------------------------------------------
// Types
// ------------------------------------------

export interface WebRTCBridgeConfig {
  sessionId: string;
  /** Function to dispatch voice events (from EngineOrchestrator) */
  dispatchEvent: (event: VoiceEvent) => Promise<void>;
  /** STT function: base64-encoded PCM → transcript */
  transcribePcm?: (pcmBase64: string, mimeType: string) => Promise<string | null>;
  /** TTS function: text → base64-encoded audio */
  synthesizeSpeech?: (text: string) => Promise<Buffer | null>;
  /** Callback to send an audio frame to the WebRTC peer */
  sendAudioFrame: (frame: Buffer) => void;
  /** VAD threshold in dBFS (default: -40) */
  vadThresholdDbfs?: number;
  /** Minimum speech duration in ms before firing USER_SPEECH_START (default: 200) */
  minSpeechDurationMs?: number;
  /** Silence duration in ms after speech to fire USER_SPEECH_FINAL (default: 1000) */
  silenceAfterSpeechMs?: number;
}

export interface WebRTCBridge {
  /** Process an inbound audio frame from the WebRTC peer */
  handleAudioFrame(frame: Buffer, timestamp: number): void;
  /** Handle an outbound TTS effect — synthesize and send to peer */
  handleSpeakText(text: string, nodeId?: string): Promise<void>;
  /** Stop any in-progress speech (barge-in) */
  stopSpeaking(): void;
  /** Destroy the bridge and release resources */
  destroy(): void;
  /** Whether the bridge is currently detecting speech */
  readonly isSpeechActive: boolean;
}

const DEFAULT_VAD_THRESHOLD_DBFS = -35;
const DEFAULT_MIN_SPEECH_DURATION_MS = 150;
const DEFAULT_SILENCE_AFTER_SPEECH_MS = 800;

// ------------------------------------------
// Factory
// ------------------------------------------

export function createWebRTCBridge(config: WebRTCBridgeConfig): WebRTCBridge {
  const {
    sessionId,
    dispatchEvent,
    transcribePcm,
    synthesizeSpeech,
    sendAudioFrame,
    vadThresholdDbfs = DEFAULT_VAD_THRESHOLD_DBFS,
    minSpeechDurationMs = DEFAULT_MIN_SPEECH_DURATION_MS,
    silenceAfterSpeechMs = DEFAULT_SILENCE_AFTER_SPEECH_MS,
  } = config;

  const decoder = createOpusDecoder();
  const encoder = createOpusEncoder();
  let destroyed = false;

  // VAD State
  let speechActive = false;
  let speechStartTime: number | null = null;
  let lastSpeechTime: number | null = null;
  let silenceTimer: ReturnType<typeof setTimeout> | null = null;

  // Audio buffer for collecting speech PCM
  const speechBuffer: Int16Array[] = [];

  // TTS cancellation
  let ttsAbortController: AbortController | null = null;

  // Local state for logging
  let pulseCounter = 0;

  // ---- Helper: dispatch safely ----
  function dispatch(event: VoiceEvent): void {
    if (destroyed) return;
    void dispatchEvent(event).catch((err) => {
      console.error('[WebRTCBridge] Dispatch error:', err);
    });
  }

  // ---- Handle silence timeout → finalize speech ----
  function onSilenceTimeout(): void {
    if (destroyed || !speechActive) return;

    speechActive = false;
    silenceTimer = null;

    // Concatenate all buffered PCM
    const totalLength = speechBuffer.reduce((acc, buf) => acc + buf.length, 0);
    const concatenated = new Int16Array(totalLength);
    let offset = 0;
    for (const chunk of speechBuffer) {
      concatenated.set(chunk, offset);
      offset += chunk.length;
    }
    speechBuffer.length = 0;

    // Convert to base64 for the STT provider
    const pcmBuffer = Buffer.from(
      concatenated.buffer,
      concatenated.byteOffset,
      concatenated.byteLength,
    );
    const pcmBase64 = pcmBuffer.toString('base64');

    console.log(`[WebRTCBridge:${sessionId}] Finalized speech: ${concatenated.length} samples. Transcribing...`);

    // Send to STT asynchronously
    if (transcribePcm) {
      void transcribePcm(pcmBase64, 'audio/pcm').then((transcript) => {
        if (destroyed || !transcript) {
          console.log(`[WebRTCBridge:${sessionId}] STT returned no transcript.`);
          return;
        }

        console.log(`[WebRTCBridge:${sessionId}] STT Result: "${transcript}"`);

        dispatch({
          type: 'USER_SPEECH_FINAL',
          sessionId,
          timestamp: new Date().toISOString(),
          payload: {
            transcript,
            confidence: 0.9, // Placeholder — real value from STT
          },
        });
      }).catch((err) => {
        console.error('[WebRTCBridge] STT error:', err);
        dispatch({
          type: 'ERROR',
          sessionId,
          timestamp: new Date().toISOString(),
          payload: { message: `STT failed: ${err instanceof Error ? err.message : String(err)}` },
        });
      });
    }
  }

  // ---- Public API ----
  const bridge: WebRTCBridge = {
    get isSpeechActive() {
      return speechActive;
    },

    handleAudioFrame(frame: Buffer, _timestamp: number): void {
      if (destroyed) return;

      // Decode Opus → PCM
      const pcmSamples = decoder.decode(frame);
      const dbfs = computeRmsDbfs(pcmSamples);
      const now = Date.now();

      // Periodic volume pulse log
      pulseCounter++;
      if (pulseCounter >= 100) {
        pulseCounter = 0;
        console.log(`[VAD:${sessionId}] Volume: ${dbfs.toFixed(1)} dBFS (Need > ${vadThresholdDbfs})`);
      }

      if (dbfs > vadThresholdDbfs) {
        // --- Speech detected ---
        lastSpeechTime = now;

        // Clear any pending silence timeout
        if (silenceTimer) {
          clearTimeout(silenceTimer);
          silenceTimer = null;
        }

        if (!speechActive) {
          // Wait for minimum speech duration before triggering
          if (speechStartTime === null) {
            speechStartTime = now;
          }

          if (now - speechStartTime >= minSpeechDurationMs) {
            speechActive = true;
            speechStartTime = null;

            console.log(`[WebRTCBridge:${sessionId}] Speech detected (VAD)`);

            dispatch({
              type: 'USER_SPEECH_START',
              sessionId,
              timestamp: new Date().toISOString(),
            });
          }
        }

        // Buffer the PCM for STT
        if (speechActive) {
          speechBuffer.push(pcmSamples);
        }
      } else {
        // --- Silence detected ---
        speechStartTime = null;

        if (speechActive && lastSpeechTime !== null) {
          // Start silence timer if not already running
          if (!silenceTimer) {
            silenceTimer = setTimeout(onSilenceTimeout, silenceAfterSpeechMs);
          }
        }
      }
    },

    async handleSpeakText(text: string, _nodeId?: string): Promise<void> {
      if (destroyed || !synthesizeSpeech) return;

      // Create AbortController for this TTS session
      ttsAbortController = new AbortController();
      const signal = ttsAbortController.signal;

      try {
        const audioBuffer = await synthesizeSpeech(text);
        if (signal.aborted || destroyed || !audioBuffer) return;

        // 1. Convert Buffer to Int16Array (PCM)
        const pcmSamples = new Int16Array(
          audioBuffer.buffer,
          audioBuffer.byteOffset,
          audioBuffer.byteLength / 2
        );

        // 2. Loop through PCM in chunks (20ms frames = 320 samples @ 16kHz)
        const FRAME_SIZE = 320; 
        for (let i = 0; i < pcmSamples.length; i += FRAME_SIZE) {
          if (signal.aborted || destroyed) break;

          const chunk = pcmSamples.slice(i, i + FRAME_SIZE);
          if (chunk.length < FRAME_SIZE) break; 

          const pcmuFrame = encoder.encode(chunk);
          sendAudioFrame(pcmuFrame);
        }
      } catch (err) {
        if (signal.aborted) return;
        console.error('[WebRTCBridge] TTS error:', err);
      }
    },

    stopSpeaking(): void {
      if (ttsAbortController) {
        ttsAbortController.abort();
        ttsAbortController = null;
      }
    },

    destroy(): void {
      if (destroyed) return;
      destroyed = true;

      if (silenceTimer) {
        clearTimeout(silenceTimer);
        silenceTimer = null;
      }

      if (ttsAbortController) {
        ttsAbortController.abort();
        ttsAbortController = null;
      }

      decoder.destroy();
      encoder.destroy();
      speechBuffer.length = 0;
    },
  };

  return bridge;
}
